# Port binding (agenthelpjob.com routes HTTPS -> 8766; override locally if you need 8765)
PORT=8766
APP_ENV=development
SECRET_KEY=change-me-in-production
DEEPSEEK_API_KEY=
AUTH_BYPASS_CODE=123456
AUTH_EXPOSE_DEBUG_CODE=1
AUTH_LOCAL_ACCOUNT_ENABLED=1
AUTH_SMS_PROVIDER=
AUTH_CODE_TTL_SECONDS=600
AUTH_EMAIL_DIRECT_ENABLED=1
AUTH_EMAIL_DIRECT_IP_WINDOW_SECONDS=900
AUTH_EMAIL_DIRECT_IP_MAX_ATTEMPTS=12
AUTH_EMAIL_DIRECT_EMAIL_WINDOW_SECONDS=900
AUTH_EMAIL_DIRECT_EMAIL_MAX_ATTEMPTS=6
AUTH_EMAIL_DIRECT_SIGNUP_WINDOW_SECONDS=86400
AUTH_EMAIL_DIRECT_IP_MAX_NEW_USERS=3
AUTH_EMAIL_DIRECT_NEW_USER_QUOTA=3
ALLOW_SELF_SERVE_UPGRADE=0
APPLY_MAX_ACTIVE_SESSIONS_PER_IP=2
ALLOW_SIMULATED_APPLY=1
DESKTOP_BACKEND_URL=

# Tencent Cloud SMS
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=
TENCENT_SMS_REGION=ap-guangzhou
TENCENT_SMS_ENDPOINT=sms.tencentcloudapi.com
TENCENT_SMS_TEMPLATE_TTL_MINUTES=10
TENCENT_SMS_DEFAULT_COUNTRY_CODE=86

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_DEFAULT_COUNTRY_CODE=86

# Frontend runtime targets (production uses https://agenthelpjob.com; override locally if needed)
VITE_API_BASE_URL=https://agenthelpjob.com
VITE_WS_BASE_URL=wss://agenthelpjob.com/api/apply/ws
